{
  "name": "nextjs-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "db:generate": "bunx --bun prisma generate",
    "db:migrate:dev": "bunx --bun prisma migrate dev",
    "db:studio": "bunx --bun prisma studio"
  },
  "dependencies": {
    "@heroui/react": "3.0.2",
    "@heroui/styles": "3.0.2",
    "@prisma/adapter-pg": "7.6.0",
    "@prisma/client": "7.6.0",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.4",
    "@tailwindcss/postcss": "4.2.2",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "clsx": "2.1.1",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.2",
    "eslint-plugin-perfectionist": "5.8.0",
    "husky": "9.1.7",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "prisma": "7.6.0",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.0"
  }
}
